-- input/output adapters

-- i/o to/from memory

#include zx0-mem-get.inc.p8

#include zx0-mem-set.inc.p8


-- input from tables

#include zx0-table-get.inc.p8

-- output to string vars

#include zx0-strvar-io.inc.p8

-->8
-- zx0 tests

function zx0_test(
	plain,
	compressed
)
 return function()
  local t = {s=""}
  
		zx0_decompress(
			table_get(compressed),
			strvar_get(t,"s"),
			strvar_set(t,"s"))
			
		assert_eq {
			expected = plain,
			actual = t.s
		}
		
		printh(" plain:      " 
		  .. #plain)
		printh(" compressed: " 
		  .. #compressed)
 end
end


